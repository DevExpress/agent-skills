@* DevExpress Blazor Ribbon — Adaptive Layout Example
   File: Pages/RibbonAdaptive.razor

   Demonstrates:
   - AdaptivityAutoCollapseItemsToGroups="true"  — each group collapses to its own button
   - AdaptivityAutoCollapseItemsToGroups="false" — all overflowing items share one overflow menu
   - DxRibbonGroup.Text + IconCssClass           — label and icon of the collapsed group button
   - DxRibbonGroup.AdaptivePriority              — group collapse order
   - DxRibbonItem.AdaptivePriority               — item collapse order within a group
   - ShowTabs="false"                            — compact single-band toolbar mode

   Resize the browser window to observe adaptive behavior.

   Program.cs setup:
   builder.Services.AddDevExpressBlazor(); *@

@page "/ribbon-adaptive"
@rendermode InteractiveServer
@using DevExpress.Blazor

<PageTitle>Ribbon — Adaptive Layout</PageTitle>
<h2>Ribbon — Adaptive Layout</h2>
<p class="text-muted mb-3">Resize the browser window to see groups collapse into labeled buttons.</p>

<!-- Toggle between the two adaptivity modes -->
<div class="mb-2 d-flex align-items-center gap-3">
    <label><strong>Collapse mode:</strong></label>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" id="perGroup" name="mode"
               checked="@collapseToGroups" @onchange="@(() => collapseToGroups = true)" />
        <label class="form-check-label" for="perGroup">Per group (default)</label>
    </div>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" id="shared" name="mode"
               checked="@(!collapseToGroups)" @onchange="@(() => collapseToGroups = false)" />
        <label class="form-check-label" for="shared">Shared overflow menu</label>
    </div>
    <div class="form-check ms-4">
        <input class="form-check-input" type="checkbox" id="hideTabs"
               @bind="hideTabs" />
        <label class="form-check-label" for="hideTabs">Hide tab captions (ShowTabs="false")</label>
    </div>
</div>

<DxRibbon AdaptivityAutoCollapseItemsToGroups="@collapseToGroups"
          ShowTabs="@(!hideTabs)">
    <DxRibbonApplicationTab Text="File">
        <DxRibbonApplicationTabItem Text="New" />
        <DxRibbonApplicationTabItem Text="Open" />
        <DxRibbonApplicationTabItem Text="Save" />
    </DxRibbonApplicationTab>

    <DxRibbonTab Text="Home">

        <!--
            AdaptivePriority on the GROUP: higher value collapses first.
            Text + IconCssClass on the GROUP: appear on the collapsed overflow button.
        -->
        <DxRibbonGroup Text="Clipboard" IconCssClass="oi oi-clipboard" AdaptivePriority="3">
            <!-- AdaptivePriority on the ITEM: within the group, lower value collapses first -->
            <DxRibbonItem Text="Paste" SplitDropDownButton="true"
                          AdaptivePriority="1"
                          Click="@(() => Log("Paste"))">
                <Items>
                    <DxRibbonItem Text="Paste Special" />
                    <DxRibbonItem Text="Paste as Plain Text" />
                </Items>
            </DxRibbonItem>
            <DxRibbonItem Text="Cut"   AdaptivePriority="2" Click="@(() => Log("Cut"))" />
            <DxRibbonItem Text="Copy"  AdaptivePriority="3" Click="@(() => Log("Copy"))" />
        </DxRibbonGroup>

        <DxRibbonGroup Text="Font" IconCssClass="oi oi-bold" AdaptivePriority="2">
            <DxRibbonComboBoxItem Data="@fontNames"
                                  @bind-Value="currentFont"
                                  NullText="Font"
                                  Width="120px" />
            <DxRibbonSpinEditItem Value="@fontSize"
                                  ValueChanged="@((int v) => fontSize = v)"
                                  MinValue="6" MaxValue="72" Increment="2"
                                  Width="70px" />
            <DxRibbonToggleItem Text="Bold"   @bind-Checked="isBold" />
            <DxRibbonToggleItem Text="Italic" @bind-Checked="isItalic" />
        </DxRibbonGroup>

        <!-- Lowest priority group — stays visible longest -->
        <DxRibbonGroup Text="Paragraph" IconCssClass="oi oi-list" AdaptivePriority="1">
            <DxRibbonToggleGroup>
                <DxRibbonToggleItem Text="Left"   @bind-Checked="alignLeft" />
                <DxRibbonToggleItem Text="Center" @bind-Checked="alignCenter" />
                <DxRibbonToggleItem Text="Right"  @bind-Checked="alignRight" />
            </DxRibbonToggleGroup>
        </DxRibbonGroup>

    </DxRibbonTab>
</DxRibbon>

<div class="mt-3">
    <p>Last action: <strong>@lastAction</strong></p>
</div>

@code {
    bool collapseToGroups = true;
    bool hideTabs = false;

    string lastAction = "—";

    bool isBold    = false;
    bool isItalic  = false;
    bool alignLeft   = true;
    bool alignCenter = false;
    bool alignRight  = false;
    int  fontSize    = 12;
    string? currentFont;

    List<string> fontNames = new() { "Arial", "Times New Roman", "Courier New", "Georgia" };

    void Log(string action) {
        lastAction = action;
        StateHasChanged();
    }
}

@* DevExpress Blazor Ribbon — Quick Start Example
   File: Pages/RibbonDemo.razor

   Prerequisites:
   1. Install NuGet package:
      dotnet add package DevExpress.Blazor

   2. Register DevExpress in Program.cs:
      builder.Services.AddDevExpressBlazor();

   3. Add to _Imports.razor (optional):
      @using DevExpress.Blazor *@

@page "/ribbon-demo"
@rendermode InteractiveServer
@using DevExpress.Blazor

<PageTitle>Ribbon Demo</PageTitle>

<DxRibbon @bind-ActiveTabIndex="activeTab">

    <!-- Application (File) Tab -->
    <DxRibbonApplicationTab Text="File">
        <DxRibbonApplicationTabItem Text="New" />
        <DxRibbonApplicationTabItem Text="Open" />
        <DxRibbonApplicationTabItem Text="Save" />
        <DxRibbonApplicationTabItem Text="Save As">
            <DxRibbonApplicationTabItem Text="PDF (.pdf)" />
            <DxRibbonApplicationTabItem Text="Plain Text (.txt)" />
        </DxRibbonApplicationTabItem>
    </DxRibbonApplicationTab>

    <!-- Home tab -->
    <DxRibbonTab Text="Home">

        <!-- Clipboard group -->
        <DxRibbonGroup>
            <DxRibbonItem Text="Paste" SplitDropDownButton="true" Click="OnPaste">
                <Items>
                    <DxRibbonItem Text="Paste Special" />
                    <DxRibbonItem Text="Paste as Plain Text" />
                </Items>
            </DxRibbonItem>
            <DxRibbonItem Text="Cut"  Click="OnCut" />
            <DxRibbonItem Text="Copy" Click="OnCopy" />
        </DxRibbonGroup>

        <!-- Font formatting group -->
        <DxRibbonGroup>
            <DxRibbonComboBoxItem Data="@FontNames"
                                  @bind-Value="CurrentFont"
                                  NullText="Font"
                                  Width="130px" />
            <DxRibbonSpinEditItem Value="@FontSize"
                                  ValueChanged="@((int v) => FontSize = v)"
                                  MinValue="6"
                                  MaxValue="72"
                                  Increment="1"
                                  Width="70px" />
            <DxRibbonToggleItem Text="Bold"      @bind-Checked="IsBold" />
            <DxRibbonToggleItem Text="Italic"    @bind-Checked="IsItalic" />
            <DxRibbonToggleItem Text="Underline" @bind-Checked="IsUnderline" />
        </DxRibbonGroup>

        <!-- Paragraph alignment group (radio-group behavior) -->
        <DxRibbonGroup>
            <DxRibbonToggleGroup>
                <DxRibbonToggleItem Text="Left"    @bind-Checked="AlignLeft" />
                <DxRibbonToggleItem Text="Center"  @bind-Checked="AlignCenter" />
                <DxRibbonToggleItem Text="Right"   @bind-Checked="AlignRight" />
                <DxRibbonToggleItem Text="Justify" @bind-Checked="AlignJustify" />
            </DxRibbonToggleGroup>
        </DxRibbonGroup>

        <!-- Highlight color group -->
        <DxRibbonGroup>
            <DxRibbonColorGroup>
                <DxRibbonColorPaletteItem @bind-Value="HighlightColor"
                                           Colors="@StandardColors"
                                           ShowNoColorTile="true">
                    <IconTemplate>
                        <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                            <span style="font-size:14px">A</span>
                            <span style="height:4px;width:16px;background:@HighlightColor;display:block"></span>
                        </div>
                    </IconTemplate>
                </DxRibbonColorPaletteItem>
            </DxRibbonColorGroup>
        </DxRibbonGroup>

    </DxRibbonTab>

    <!-- Insert tab -->
    <DxRibbonTab Text="Insert">
        <DxRibbonGroup>
            <DxRibbonItem Text="Table" />
            <DxRibbonItem Text="Image" Click="SelectImage" />
            <DxRibbonItem Text="Hyperlink" />
        </DxRibbonGroup>
    </DxRibbonTab>

    <!-- Contextual tab: appears only when an image is selected -->
    <DxRibbonTab Text="Picture Format" Contextual="true" Visible="@ImageSelected">
        <DxRibbonGroup>
            <DxRibbonItem Text="Crop" />
            <DxRibbonItem Text="Rotate" />
        </DxRibbonGroup>
        <DxRibbonGroup>
            <DxRibbonItem Text="Brightness" />
            <DxRibbonItem Text="Contrast" />
        </DxRibbonGroup>
    </DxRibbonTab>

</DxRibbon>

<!-- Status display -->
<div class="mt-3">
    <p>Font: <strong>@(CurrentFont ?? "none")</strong>, Size: <strong>@FontSize</strong></p>
    <p>Bold: <strong>@IsBold</strong>, Italic: <strong>@IsItalic</strong></p>
    <p>Alignment: <strong>@GetAlignment()</strong></p>
    <p>Highlight: <strong style="background:@HighlightColor">@HighlightColor</strong></p>
    <p>Image selected: <strong>@ImageSelected</strong></p>
    <button @onclick="() => ImageSelected = !ImageSelected">Toggle Image Selection</button>
</div>

@code {
    int activeTab = 0;

    // Font state
    string? CurrentFont { get; set; }
    int FontSize { get; set; } = 12;
    List<string> FontNames = new() { "Arial", "Calibri", "Georgia", "Times New Roman", "Verdana" };

    // Text formatting
    bool IsBold      { get; set; } = false;
    bool IsItalic    { get; set; } = false;
    bool IsUnderline { get; set; } = false;

    // Alignment (radio group)
    bool AlignLeft    { get; set; } = true;
    bool AlignCenter  { get; set; } = false;
    bool AlignRight   { get; set; } = false;
    bool AlignJustify { get; set; } = false;

    // Color
    string HighlightColor = "#FFFF00";
    List<string> StandardColors = new() {
        "#FF0000", "#FF6600", "#FFFF00", "#00FF00",
        "#00FFFF", "#0000FF", "#8B00FF", "#FF00FF",
        "#FFFFFF", "#CCCCCC", "#888888", "#000000"
    };

    // Contextual tab state
    bool ImageSelected { get; set; } = false;

    // Item click handlers
    void OnPaste() { }
    void OnCut()   { }
    void OnCopy()  { }

    void SelectImage() {
        ImageSelected = true;
        // Switch to the contextual tab when image is selected
        activeTab = 3; // index of "Picture Format" contextual tab
    }

    string GetAlignment() =>
        AlignLeft ? "Left" : AlignCenter ? "Center" : AlignRight ? "Right" : "Justify";
}

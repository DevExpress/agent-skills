@* DevExpress Blazor Toolbar — Adaptive Layout Example
   File: Pages/ToolbarAdaptive.razor

   Demonstrates:
   - AdaptivityAutoCollapseItemsToIcons — hides text, keeps icons when space is tight
   - AdaptivityAutoHideRootItems        — moves root items to overflow submenu
   - AdaptivityMinRootItemCount         — keeps N items always visible
   - AdaptivePriority per item          — lower value = hidden first
   - AdaptiveText                       — label used in the overflow submenu

   Resize the browser window to see the toolbar adapt in real time.

   Program.cs setup:
   builder.Services.AddDevExpressBlazor(); *@

@page "/toolbar-adaptive"
@rendermode InteractiveServer
@using DevExpress.Blazor

<PageTitle>Toolbar — Adaptive Layout</PageTitle>
<h1>Toolbar — Adaptive Layout</h1>
<p class="text-muted">Resize the browser window to observe adaptive behavior.</p>

<DxToolbar Title="Editor"
           AdaptivityAutoCollapseItemsToIcons="true"
           AdaptivityAutoHideRootItems="true"
           AdaptivityMinRootItemCount="2">
    <Items>
        <!--
            Priority 1 = highest priority (stays visible longest).
            Priority 5 = lowest priority (moves to overflow first).
            Items without icons collapse to the overflow menu when AdaptivityAutoCollapseItemsToIcons is true.
        -->

        <!-- Always-visible: high priority, has icon -->
        <DxToolbarItem Text="Save"
                       IconCssClass="oi oi-cloud-upload"
                       AdaptivePriority="1"
                       AdaptiveText="Save document"
                       Click="@(_ => Log("Save"))" />

        <!-- Medium priority — visible until space runs short -->
        <DxToolbarItem Text="Open"
                       IconCssClass="oi oi-folder-open"
                       AdaptivePriority="2"
                       AdaptiveText="Open file"
                       Click="@(_ => Log("Open"))" />

        <DxToolbarItem Text="Undo"
                       IconCssClass="oi oi-action-undo"
                       AdaptivePriority="3"
                       AdaptiveText="Undo"
                       BeginGroup="true"
                       Click="@(_ => Log("Undo"))" />

        <DxToolbarItem Text="Redo"
                       IconCssClass="oi oi-action-redo"
                       AdaptivePriority="3"
                       AdaptiveText="Redo"
                       Click="@(_ => Log("Redo"))" />

        <!-- Lower priority — collapses early -->
        <DxToolbarItem Text="Print"
                       IconCssClass="oi oi-print"
                       AdaptivePriority="4"
                       AdaptiveText="Print document"
                       BeginGroup="true"
                       Click="@(_ => Log("Print"))" />

        <DxToolbarItem Text="Share"
                       IconCssClass="oi oi-share"
                       AdaptivePriority="4"
                       AdaptiveText="Share"
                       Click="@(_ => Log("Share"))" />

        <!-- Lowest priority — collapses first; text-only items move to overflow -->
        <DxToolbarItem Text="Properties"
                       AdaptivePriority="5"
                       AdaptiveText="Document properties"
                       BeginGroup="true"
                       Click="@(_ => Log("Properties"))" />

        <!-- Right-aligned — always stays in place -->
        <DxToolbarItem IconCssClass="oi oi-cog"
                       Tooltip="Settings"
                       Alignment="ToolbarItemAlignment.Right"
                       Click="@(_ => Log("Settings"))" />
    </Items>
</DxToolbar>

<div class="mt-3">
    <p>Last action: <strong>@lastAction</strong></p>
</div>

@code {
    string lastAction = "—";

    void Log(string action) {
        lastAction = action;
        StateHasChanged();
    }
}

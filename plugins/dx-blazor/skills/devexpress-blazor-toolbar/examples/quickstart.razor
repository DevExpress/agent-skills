@* DevExpress Blazor Toolbar — Quick Start Example
   File: Pages/ToolbarDemo.razor

   Prerequisites:
   1. Install NuGet package:
      dotnet add package DevExpress.Blazor

   2. Register DevExpress in Program.cs:
      builder.Services.AddDevExpressBlazor();

   3. Add to _Imports.razor (optional):
      @using DevExpress.Blazor *@

@page "/toolbar-demo"
@rendermode InteractiveServer
@using DevExpress.Blazor

<PageTitle>Toolbar Demo</PageTitle>
<h1>Toolbar Demo</h1>

<DxToolbar Title="Text Editor"
           AdaptivityAutoCollapseItemsToIcons="true"
           AdaptivityAutoHideRootItems="true"
           AdaptivityMinRootItemCount="3">
    <Items>
        <!-- File actions -->
        <DxToolbarItem Text="New"  IconCssClass="oi oi-file"        Click="OnNew"
                       AdaptivePriority="3" AdaptiveText="New" />
        <DxToolbarItem Text="Open" IconCssClass="oi oi-folder-open" Click="OnOpen"
                       AdaptivePriority="3" AdaptiveText="Open" />
        <DxToolbarItem Text="Save" IconCssClass="oi oi-cloud-upload" Click="OnSave"
                       BeginGroup="true"
                       AdaptivePriority="1" AdaptiveText="Save" />

        <!-- Alignment radio group -->
        <DxToolbarItem GroupName="align" IconCssClass="oi oi-align-left"
                       Tooltip="Align Left"
                       BeginGroup="true"
                       @bind-Checked="AlignLeft"
                       AdaptivePriority="2" AdaptiveText="Left" />
        <DxToolbarItem GroupName="align" IconCssClass="oi oi-align-center"
                       Tooltip="Align Center"
                       @bind-Checked="AlignCenter"
                       AdaptivePriority="2" AdaptiveText="Center" />
        <DxToolbarItem GroupName="align" IconCssClass="oi oi-align-right"
                       Tooltip="Align Right"
                       @bind-Checked="AlignRight"
                       AdaptivePriority="2" AdaptiveText="Right" />

        <!-- Drop-down format menu -->
        <DxToolbarItem Text="Format" BeginGroup="true">
            <Items>
                <DxToolbarItem Text="Bold" />
                <DxToolbarItem Text="Italic" />
                <DxToolbarItem Text="Underline" />
            </Items>
        </DxToolbarItem>

        <!-- Right-aligned settings icon -->
        <DxToolbarItem IconCssClass="oi oi-cog"
                       Tooltip="Settings"
                       Alignment="ToolbarItemAlignment.Right" />
    </Items>
</DxToolbar>

<div class="mt-3">
    <p>Last action: <strong>@lastAction</strong></p>
    <p>Alignment: <strong>@GetAlignment()</strong></p>
</div>

@code {
    string lastAction = "none";

    bool AlignLeft   { get; set; } = true;
    bool AlignCenter { get; set; } = false;
    bool AlignRight  { get; set; } = false;

    void OnNew(ToolbarItemClickEventArgs _)  => lastAction = "New";
    void OnOpen(ToolbarItemClickEventArgs _) => lastAction = "Open";
    void OnSave(ToolbarItemClickEventArgs _) => lastAction = "Save";

    string GetAlignment() =>
        AlignLeft ? "Left" : AlignCenter ? "Center" : "Right";
}

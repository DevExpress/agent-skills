@* DevExpress Blazor Toolbar — Split Drop-Down Button Example
   File: Pages/ToolbarSplitDropDown.razor

   Demonstrates:
   - SplitDropDownButton="true" — splits an item into a main button + drop-down arrow
   - Clicking the main area fires Click; clicking the arrow opens sub-items
   - Nesting multiple levels of drop-down items
   - Using the global ItemClick handler as an alternative to per-item Click

   Program.cs setup:
   builder.Services.AddDevExpressBlazor(); *@

@page "/toolbar-split-dropdown"
@rendermode InteractiveServer
@using DevExpress.Blazor

<PageTitle>Toolbar — Split Drop-Down Buttons</PageTitle>
<h1>Toolbar — Split Drop-Down Buttons</h1>

<DxToolbar>
    <Items>
        <!--
            SplitDropDownButton="true":
              - Left area  → fires Click ("Paste" action)
              - Right area → opens the drop-down with sub-items
        -->
        <DxToolbarItem Text="Paste"
                       IconCssClass="oi oi-clipboard"
                       SplitDropDownButton="true"
                       Click="@(_ => Log("Paste"))">
            <Items>
                <DxToolbarItem Text="Paste Special"         Click="@(_ => Log("Paste Special"))" />
                <DxToolbarItem Text="Paste as Plain Text"   Click="@(_ => Log("Paste as Plain Text"))" />
                <DxToolbarItem Text="Paste Formatting Only" Click="@(_ => Log("Paste Formatting Only"))" />
            </Items>
        </DxToolbarItem>

        <!-- Regular drop-down (no split) — entire item opens the menu -->
        <DxToolbarItem Text="Insert" BeginGroup="true">
            <Items>
                <DxToolbarItem Text="Image"     Click="@(_ => Log("Insert Image"))" />
                <DxToolbarItem Text="Table"     Click="@(_ => Log("Insert Table"))" />
                <DxToolbarItem Text="Hyperlink" Click="@(_ => Log("Insert Hyperlink"))" />
            </Items>
        </DxToolbarItem>

        <!-- Another split button for Save actions -->
        <DxToolbarItem Text="Save"
                       IconCssClass="oi oi-cloud-upload"
                       SplitDropDownButton="true"
                       Click="@(_ => Log("Save"))">
            <Items>
                <DxToolbarItem Text="Save as PDF"  Click="@(_ => Log("Save as PDF"))" />
                <DxToolbarItem Text="Save as DOCX" Click="@(_ => Log("Save as DOCX"))" />
                <DxToolbarItem Text="Save as TXT"  Click="@(_ => Log("Save as TXT"))" />
            </Items>
        </DxToolbarItem>
    </Items>
</DxToolbar>

<div class="mt-3">
    <p>Last action: <strong>@lastAction</strong></p>
</div>

@code {
    string lastAction = "—";

    void Log(string action) {
        lastAction = action;
        StateHasChanged();
    }
}

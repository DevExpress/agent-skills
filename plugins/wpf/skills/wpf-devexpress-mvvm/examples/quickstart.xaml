    <dxmvvm:ConfirmationBehavior MessageTitle="Unsaved changes"
                                 MessageText="Discard unsaved changes?"
                                 MessageButton="YesNo"
                                 MessageIcon="Warning"
                                 MessageDefaultResult="Yes"
                                 Command="{Binding SaveCommand}"/>
</dxmvvm:Interaction.Behaviors>

<Window x:Class="MyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
        DataContext="{dxmvvm:ViewModelSource Type=local:MainViewModel}"
        Title="DevExpress Data Grid Quickstart" Height="500" Width="800">

    <!-- 1. Basic grid with explicit columns, sorting, grouping, editing enabled -->
    <dxg:GridControl ItemsSource="{Binding Orders}">
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Id"        Header="ID"       Width="50" ReadOnly="True"/>
            <dxg:GridColumn FieldName="Customer"  Header="Customer"/>
            <dxg:GridColumn FieldName="Product"   Header="Product"/>
            <dxg:GridColumn FieldName="Total"     Header="Total"    DisplayFormat="c2"/>
            <dxg:GridColumn FieldName="OrderDate" Header="Date"     DisplayFormat="d"/>
            <dxg:GridColumn FieldName="Status"    Header="Status"/>
        </dxg:GridControl.Columns>
        <dxg:GridControl.View>
            <dxg:TableView AllowEditing="True"
                           ShowGroupPanel="True"
                           SearchPanelAllowFilter="True"
                           ValidateRow="OnValidateRow"/>
        </dxg:GridControl.View>
    </dxg:GridControl>

</Window>


<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- AIChatControl Quickstart credentials (mirrors the dx.wpf.aichat CLI template). -->
  <!-- The demo endpoint/key below are the rate-limited DevExpress demo credentials, -->
  <!-- intended for evaluation only. Replace them with your own Azure OpenAI resource -->
  <!-- before shipping; using demo credentials in production is prohibited. -->
  <appSettings>
    <!-- Azure OpenAI: resource endpoint, for example: https://<resource>.openai.azure.com -->
    <add key="AzureOpenAI.Endpoint" value="https://api.devexpress.com/demo-openai" />
    <!-- Azure OpenAI: API key for authentication -->
    <add key="AzureOpenAI.Key" value="demo" />
    <!-- Azure OpenAI: deployment name of the model to be used -->
    <add key="AzureOpenAI.Deployment" value="demo" />
  </appSettings>
</configuration>

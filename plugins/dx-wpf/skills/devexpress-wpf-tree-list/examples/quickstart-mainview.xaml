<!--
  Quickstart MainView for the DevExpress WPF TreeList.
  Drop this into a new WPF .NET 8 project after adding the
  DevExpress.Wpf.Grid.Core NuGet package.

  Verified APIs (apidoc / lesson articles):
    - DevExpress.Xpf.Grid.TreeListControl
    - DevExpress.Xpf.Grid.TreeListView (KeyFieldName, ParentFieldName,
      AutoWidth, AutoExpandAllNodes, AllowHeaderNavigation)
    - DevExpress.Xpf.Grid.TreeListColumn (FieldName, Header, Width)
-->
<Window x:Class="DevExpressTreeListQuickstart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:vm="clr-namespace:DevExpressTreeListQuickstart.ViewModels"
        Title="DevExpress WPF TreeList Quickstart"
        Height="500" Width="800">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <dxg:TreeListControl ItemsSource="{Binding Employees}"
                             AutoGenerateColumns="None"
                             EnableSmartColumnsGeneration="True">
            <dxg:TreeListControl.View>
                <dxg:TreeListView KeyFieldName="ID"
                                  ParentFieldName="ParentID"
                                  AutoWidth="True"
                                  AutoExpandAllNodes="True"
                                  AllowHeaderNavigation="True"/>
            </dxg:TreeListControl.View>

            <dxg:TreeListColumn FieldName="Name"       Header="Employee" Width="220"/>
            <dxg:TreeListColumn FieldName="Department" Header="Dept"     Width="120"/>
            <dxg:TreeListColumn FieldName="Position"   Header="Position" Width="160"/>
        </dxg:TreeListControl>
    </Grid>
</Window>

<Window x:Class="MyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
        Title="DevExpress Charts Quickstart" Height="450" Width="700">

    <!-- 1. Bar chart — multiple series from a shared DataSource -->
    <dxc:ChartControl x:Name="chartControl" DataSource="{Binding Sales}">
        <dxc:ChartControl.Legend>
            <dxc:Legend HorizontalPosition="Right" VerticalPosition="Top"/>
        </dxc:ChartControl.Legend>
        <dxc:XYDiagram2D>
            <dxc:XYDiagram2D.AxisX>
                <dxc:AxisX2D>
                    <dxc:AxisX2D.Title>
                        <dxc:AxisTitle Content="Region"/>
                    </dxc:AxisX2D.Title>
                </dxc:AxisX2D>
            </dxc:XYDiagram2D.AxisX>
            <dxc:XYDiagram2D.AxisY>
                <dxc:AxisY2D>
                    <dxc:AxisY2D.Title>
                        <dxc:AxisTitle Content="USD (M)"/>
                    </dxc:AxisY2D.Title>
                </dxc:AxisY2D>
            </dxc:XYDiagram2D.AxisY>

            <dxc:BarSideBySideSeries2D DisplayName="Revenue"
                                       ArgumentDataMember="Region"
                                       ValueDataMember="Revenue"
                                       LabelsVisibility="True"/>
            <dxc:BarSideBySideSeries2D DisplayName="Expenses"
                                       ArgumentDataMember="Region"
                                       ValueDataMember="Expenses"/>
        </dxc:XYDiagram2D>
    </dxc:ChartControl>

</Window>


<Window x:Class="MyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
        xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        Title="DevExpress Layout Management Quickstart" Height="600" Width="900">

    <!-- 1. DockLayoutManager — Visual-Studio-style shell -->
    <dxdo:DockLayoutManager x:Name="dockManager">
        <dxdo:LayoutGroup Orientation="Horizontal">

            <!-- Left panel — tool window -->
            <dxdo:LayoutPanel Caption="Solution Explorer" ItemWidth="220">
                <TreeView/>
            </dxdo:LayoutPanel>

            <!-- Center — document tabs -->
            <dxdo:DocumentGroup x:Name="documentGroup">
                <dxdo:DocumentPanel Caption="Start Page">
                    <TextBlock Text="Welcome!" Margin="8"/>
                </dxdo:DocumentPanel>
                <dxdo:DocumentPanel Caption="MainWindow.xaml">
                    <TextBox Text="XAML content here…" AcceptsReturn="True"/>
                </dxdo:DocumentPanel>
            </dxdo:DocumentGroup>

            <!-- Right panel — properties -->
            <dxdo:LayoutPanel Caption="Properties" ItemWidth="200">
                <TextBlock Text="Properties here" Margin="4"/>
            </dxdo:LayoutPanel>

        </dxdo:LayoutGroup>
    </dxdo:DockLayoutManager>

</Window>


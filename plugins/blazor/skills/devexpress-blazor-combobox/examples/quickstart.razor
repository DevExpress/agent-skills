@* quickstart.razor
   DevExpress Blazor ComboBox — Quick Start
   Requires: @rendermode InteractiveServer (or InteractiveWebAssembly / InteractiveAuto)
   NuGet:     DevExpress.Blazor
   Setup:     builder.Services.AddDevExpressBlazor();
              @using DevExpress.Blazor in _Imports.razor
              @DxResourceManager.RegisterTheme(Themes.Fluent) in App.razor
*@

@page "/combobox-quickstart"
@rendermode InteractiveServer

<h3>DevExpress ComboBox – Quick Start</h3>

<h4>1. Simple String List</h4>
<DxComboBox Data="@Cities"
            @bind-Value="@SelectedCity"
            NullText="Select a city…"
            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
<p>Selected: @SelectedCity</p>

<h4>2. Search &amp; Filter</h4>
<DxComboBox Data="@Cities"
            @bind-Value="@FilteredCity"
            NullText="Type to search…"
            SearchMode="ListSearchMode.AutoSearch"
            SearchFilterCondition="ListSearchFilterCondition.Contains" />

<h4>3. Cascading ComboBoxes (Country → City)</h4>
<div style="display:flex; gap:1rem;">
    <DxComboBox Data="@Countries"
                TextFieldName="@nameof(Country.Name)"
                Value="@SelectedCountry"
                ValueChanged="@((Country c) => OnCountryChanged(c))"
                NullText="Select country…" />

    <DxComboBox Data="@FilteredCities"
                TextFieldName="@nameof(City.Name)"
                @bind-Value="@SelectedCity2"
                NullText="Select city…" />
</div>
<p>Country: @SelectedCountry?.Name — City: @SelectedCity2?.Name</p>

@code {
    // ── 1. Simple string list ──────────────────────────────────────────────
    IEnumerable<string> Cities = new List<string> { "London", "Berlin", "Paris", "Tokyo", "New York" };
    string SelectedCity { get; set; }
    string FilteredCity { get; set; }

    // ── 2. Cascading ──────────────────────────────────────────────────────
    record Country(int Id, string Name);
    record City(int CountryId, string Name);

    static readonly List<Country> Countries = new()
    {
        new(1, "Germany"), new(2, "France"), new(3, "USA")
    };

    static readonly List<City> AllCities = new()
    {
        new(1, "Berlin"), new(1, "Munich"),
        new(2, "Paris"), new(2, "Lyon"),
        new(3, "New York"), new(3, "Chicago")
    };

    Country SelectedCountry { get; set; } = Countries[0];
    City SelectedCity2 { get; set; }
    List<City> FilteredCities { get; set; } = new();

    protected override void OnInitialized() => OnCountryChanged(SelectedCountry);

    void OnCountryChanged(Country country)
    {
        SelectedCountry = country;
        FilteredCities = AllCities.Where(c => c.CountryId == country.Id).ToList();
        SelectedCity2 = FilteredCities.FirstOrDefault();
    }
}
